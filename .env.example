# .env.example — copy to .env and fill in values
# See README for all accepted values.

# ── Required ─────────────────────────────────────────────────────────────────

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# App URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────

# Uses bundled finansas-db by default.
# To use your own Postgres: set this and remove/comment finansas-db from compose.
DATABASE_URL=postgresql://finansas:finansas@finansas-db:5432/finansas

# Required only when using bundled finansas-db
POSTGRES_PASSWORD=finansas

# ── Uploads ───────────────────────────────────────────────────────────────────

# Path inside the container where receipts are stored.
# Mount a volume here for persistence.
UPLOADS_DIR=/data/uploads

# ── Locale & Formatting ───────────────────────────────────────────────────────

# UI language
# Accepted: en | pt-BR
# Default:  en
NEXT_PUBLIC_LOCALE=en

# Currency code (ISO 4217)
# Accepted: USD | BRL | EUR | GBP | JPY | CAD | AUD | CHF | ...any ISO 4217 code
# Default:  USD
NEXT_PUBLIC_CURRENCY=USD

# Date format
# Accepted: mdy (MM/dd/yyyy) | dmy (dd/MM/yyyy)
# Default:  mdy
NEXT_PUBLIC_DATE_FORMAT=mdy

# Time format
# Accepted: 12 (12h AM/PM) | 24 (24h)
# Default:  12
NEXT_PUBLIC_TIME_FORMAT=12

# ── Optional ──────────────────────────────────────────────────────────────────

# Port exposed by the app container (default: 3000)
# PORT=3000
